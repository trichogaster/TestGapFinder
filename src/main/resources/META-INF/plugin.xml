<idea-plugin>
    <id>io.github.trichogaster.TestGapFinder</id>
    <name>Test Gap Finder</name>
    <vendor email="dmitic3322rn@raf.rs" url="https://github.com/trichogaster">Trichogaster</vendor>

    <description><![CDATA[
        AI-assisted IntelliJ plugin that suggests likely overlooked test scenarios for a selected Java method.
    ]]></description>

    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>com.intellij.properties</depends>

    <resource-bundle>messages.TestGapBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.lineMarkerProvider
                language="JAVA"
                implementationClass="io.github.trichogaster.gutter.MethodTestGapLineMarkerProvider"/>
        <applicationConfigurable
                id="io.github.trichogaster.settings.llm"
                parentId="tools"
                displayName="Test Gap Finder"
                instance="io.github.trichogaster.settings.LlmSettingsConfigurable"/>
        <toolWindow
                id="Test Gap Finder"
                anchor="right"
                factoryClass="io.github.trichogaster.ui.toolwindow.TestGapResultsToolWindowFactory"
                canCloseContents="false"/>
    </extensions>

    <actions>
        <action
                id="io.github.trichogaster.FindLikelyTestGapsAction"
                class="io.github.trichogaster.actions.FindTestGapsAction"
                text="Find Likely Test Gaps"
                description="Analyze selected code and suggest likely missing test scenarios">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
</idea-plugin>
